<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<title>Hood Lens</title>
<style>
body {
  background:#0d0d0d;
  color:white;
  font-family:Arial;
  padding:40px;
}
h1 { color:#00c805; }
input, textarea {
  display:block;
  margin:10px 0;
  padding:10px;
  width:300px;
}
button {
  background:#00c805;
  border:none;
  padding:10px;
  cursor:pointer;
}
.card {
  background:#1a1a1a;
  padding:20px;
  margin:10px 0;
  border-radius:10px;
}
</style>
</head><body><h1>🟢 Hood Lens</h1><h3>Add Project</h3><input id="name" placeholder="Name">
<input id="symbol" placeholder="Symbol">
<input id="website" placeholder="Website">
<textarea id="desc" placeholder="Description"></textarea><button onclick="addProject()">Add</button>

<h3>Projects</h3>
<div id="list"></div><script>
let projects = [];

function addProject(){
  const p = {
    name: document.getElementById("name").value,
    symbol: document.getElementById("symbol").value,
    website: document.getElementById("website").value,
    desc: document.getElementById("desc").value
  };

  projects.push(p);
  render();
}

function render(){
  const list = document.getElementById("list");
  list.innerHTML = "";

  projects.forEach(p => {
    list.innerHTML += `
      <div class="card">
        <h3>${p.name} (${p.symbol})</h3>
        <p>${p.desc}</p>
        <a href="${p.website}" target="_blank">Visit</a>
      </div>
    `;
  });
}
</script></body>
</html>
